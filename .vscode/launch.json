            "request": "launch",
            "module": "server"
        },
        {
            "name": "Client Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "client"
        },
        {
            "name": "Unittests Debug",
            "type": "debugpy",
            "request": "launch",
